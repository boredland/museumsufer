{
  "name": "@museumsufer/frankfurt-museums",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "css": "lightningcss --minify --targets '>0.25%, last 2 versions, not dead' -o public/styles.css src/app.css && bun scripts/inline-css.mjs",
    "css:watch": "lightningcss --minify --targets '>0.25%, last 2 versions, not dead' -o public/styles.css src/app.css && bun scripts/inline-css.mjs",
    "dev": "bun css && wrangler dev",
    "build": "bun css",
    "deploy": "bun css && wrangler d1 migrations apply museumsufer-db --remote && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply museumsufer-db --local",
    "db:migrate": "wrangler d1 migrations apply museumsufer-db --remote",
    "scrape": "bun scripts/scrape.ts",
    "lint": "biome check src/ scripts/",
    "lint:fix": "biome check --write src/ scripts/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@museumsufer/core": "*",
    "@scalar/hono-api-reference": "^0.10.14",
    "dayjs": "^1.11.20",
    "fuse.js": "^7.3.0",
    "hono": "^4.12.18",
    "htmx.org": "^2.0.10",
    "p-queue": "^9.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260509.1",
    "@museumsufer/tsconfig": "*",
    "lightningcss-cli": "^1.32.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.90.0"
  }
}
