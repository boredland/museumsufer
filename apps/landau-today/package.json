{
  "name": "@museumsufer/landau-today",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "css": "lightningcss --minify --targets '>0.25%, last 2 versions, not dead' -o public/styles.css src/app.css",
    "css:watch": "lightningcss --minify --targets '>0.25%, last 2 versions, not dead' -o public/styles.css src/app.css",
    "dev": "bun css && wrangler dev",
    "build": "bun css",
    "deploy": "bun css && wrangler d1 migrations apply landau-today-db --remote && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply landau-today-db --local",
    "db:migrate": "wrangler d1 migrations apply landau-today-db --remote",
    "scrape": "bun scripts/scrape.ts",
    "lint": "biome check src/ scripts/",
    "lint:fix": "biome check --write src/ scripts/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@museumsufer/core": "*",
    "@scalar/hono-api-reference": "^0.10.14",
    "dayjs": "^1.11.20",
    "hono": "^4.12.18",
    "p-queue": "^9.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260509.1",
    "@museumsufer/tsconfig": "*",
    "lightningcss-cli": "^1.32.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.90.0"
  }
}
