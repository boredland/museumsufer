{
  "name": "@museumsufer/frankfurt-theaters",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "echo 'no build step yet'",
    "deploy": "wrangler d1 migrations apply frankfurt-theaters-db --remote && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply frankfurt-theaters-db --local",
    "db:migrate": "wrangler d1 migrations apply frankfurt-theaters-db --remote",
    "lint": "../../node_modules/.bin/biome check src/",
    "lint:fix": "../../node_modules/.bin/biome check --write src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.10.14",
    "dayjs": "^1.11.20",
    "hono": "^4.12.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "@museumsufer/tsconfig": "*",
    "typescript": "^5.8.3",
    "wrangler": "^4.83.0"
  }
}
