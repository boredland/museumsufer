{
  "name": "museumsufer",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "css": "tailwindcss -i src/app.css -o public/styles.css --minify",
    "css:watch": "tailwindcss -i src/app.css -o public/styles.css --watch",
    "dev": "npm run css && wrangler dev",
    "deploy": "npm run css && wrangler d1 migrations apply museumsufer-db --remote && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply museumsufer-db --local",
    "db:migrate": "wrangler d1 migrations apply museumsufer-db --remote",
    "health-check": "npx tsx scripts/health-check.ts",
    "lint": "biome check src/ scripts/",
    "lint:fix": "biome check --write src/ scripts/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/workers-types": "^4.20250410.0",
    "@tailwindcss/cli": "^4.2.4",
    "lefthook": "^2.1.6",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.10.11",
    "dayjs": "^1.11.20",
    "fuse.js": "^7.0.0",
    "hono": "^4.12.15",
    "htmx.org": "^2.0.4",
    "zod": "^4.3.6"
  }
}
