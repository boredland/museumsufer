{
  "name": "museumsufer",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "deploy": "turbo run deploy",
    "health-check": "turbo run health-check",
    "screenshot": "turbo run screenshot",
    "screenshots:manifest": "turbo run screenshots:manifest",
    "db:migrate:local": "turbo run db:migrate:local",
    "db:migrate": "turbo run db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "lefthook": "^2.1.6",
    "turbo": "^2.3.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22"
  }
}
