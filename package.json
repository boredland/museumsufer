{
  "name": "museumsufer",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute museumsufer-db --local --file=./migrations/0001_init.sql",
    "db:migrate": "wrangler d1 execute museumsufer-db --file=./migrations/0001_init.sql",
    "health-check": "npx tsx scripts/health-check.ts",
    "lint": "biome check src/ scripts/",
    "lint:fix": "biome check --write src/ scripts/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cloudflare/workers-types": "^4.20250410.0",
    "lefthook": "^2.1.6",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "dayjs": "^1.11.20"
  }
}
